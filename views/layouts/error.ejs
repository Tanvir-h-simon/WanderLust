<% layout("/layouts/boilerplate") %>

<div class="container" style="margin-top: 4rem; text-align: center;">
    <div style="padding: 3rem 2rem; background-color: #fff5f5; border-left: 4px solid #dc3545; border-radius: 8px;">
        <h1 style="color: #dc3545; margin-bottom: 1rem; font-size: 4rem;">
            <%= statusCode %>
        </h1>
        <h2 style="color: #222222; margin-bottom: 1.5rem; font-size: 1.8rem;">
            <%= message %>
        </h2>
        <p style="color: #717171; margin-bottom: 2rem; font-size: 1rem;">
            <% if (statusCode === 404) { %>
                Sorry, the page you're looking for doesn't exist.
            <% } else if (statusCode === 400) { %>
                It looks like there was a problem with your request.
            <% } else { %>
                An error has occurred. Please try again later.
            <% } %>
        </p>
        <a href="/" class="btn btn-danger" style="text-decoration: none; padding: 0.75rem 2rem;">
            <i class="fa-solid fa-arrow-left"></i> Back to Home
        </a>
    </div>
</div>
