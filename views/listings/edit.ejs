<% layout("/layouts/boilerplate") %>
<div class="container new-listing-container">
    <h3 class="new-listing-heading">Edit Your Listing</h3>
    <form action="/listings/<%= listing._id %>?_method=PUT" method="POST" enctype="multipart/form-data" novalidate class="needs-validation new-listing-form">
        <div class="mb-3">
            <label for="title" class="form-label">Title:</label>
            <input type="text" id="title" name="title" value="<%= listing.title %>" class="form-control" placeholder="Enter title" required>
            <div class="invalid-feedback"> Please enter a valid title. </div>
        </div>
        <div class="mb-3">
            <label for="description" class="form-label">Description:</label>
            <textarea id="description" name="description" class="form-control" placeholder="Enter description" required><%= listing.description %></textarea>
            <div class="invalid-feedback"> Please enter a description. </div>
        </div>
        <div class="mb-4">
            <label class="form-label">Category</label>
            <div class="cat-picker">
                <% [
                    { key: 'beach',       icon: 'fa-solid fa-umbrella-beach',  label: 'Beach'       },
                    { key: 'city',        icon: 'fa-solid fa-city',            label: 'City'        },
                    { key: 'mountains',   icon: 'fa-solid fa-mountain-sun',    label: 'Mountains'   },
                    { key: 'cabins',      icon: 'fa-solid fa-tree',            label: 'Cabins'      },
                    { key: 'pools',       icon: 'fa-solid fa-person-swimming', label: 'Pools'       },
                    { key: 'lake',        icon: 'fa-solid fa-sailboat',        label: 'Lakefront'   },
                    { key: 'island',      icon: 'fa-solid fa-water',           label: 'Islands'     },
                    { key: 'desert',      icon: 'fa-solid fa-sun',             label: 'Desert'      },
                    { key: 'rooms',       icon: 'fa-solid fa-door-open',       label: 'Rooms'       },
                    { key: 'ski',         icon: 'fa-solid fa-person-skiing',   label: 'Skiing'      },
                    { key: 'countryside', icon: 'fa-solid fa-leaf',            label: 'Countryside' },
                ].forEach(cat => { %>
                <label class="cat-tile">
                    <input type="radio" name="category" value="<%= cat.key %>" class="cat-tile-input"
                        <%= listing.category === cat.key ? 'checked' : '' %>>
                    <span class="cat-tile-body">
                        <i class="<%= cat.icon %>"></i>
                        <span><%= cat.label %></span>
                    </span>
                </label>
                <% }); %>
            </div>
        </div>
        <div class="mb-3">
            <%# Old URL input — replaced by file upload %>
            <%# <label for="image" class="form-label">Image URL:</label> %>
            <%# <input type="text" id="image" name="image[url]" value="<%= (listing.image && (listing.image.url || listing.image)) || '' %>" class="form-control" placeholder="Enter image URL" required> %>
            <%# <div class="invalid-feedback"> Please enter a valid image URL. </div> %>
            <% if (listing.image && listing.image.url) { %>
            <div class="mb-2">
                <img src="<%= listing.image.url %>" alt="Current image" style="max-height:150px; border-radius:8px;">
                <small class="d-block text-muted mt-1">Current image</small>
            </div>
            <% } %>
            <label for="image" class="form-label">Upload New Image <span class="text-muted">(optional — leave blank to keep current)</span>:</label>
            <input type="file" id="image" name="image" class="form-control" accept="image/jpeg,image/jpg,image/png">
        </div>
        <div class="row">
            <div class="mb-3 col-md-8">
                <label for="price" class="form-label">Price (per night):</label>
                <input type="number" id="price" name="price" value="<%= listing.price %>" class="form-control" step="0.01" placeholder="e.g., 3000" required>
                <div class="invalid-feedback"> Please enter a valid price. </div>
            </div>
            <div class="mb-3 col-md-4">
                <label for="maxGuests" class="form-label">Max guests:</label>
                <input type="number" id="maxGuests" name="maxGuests" value="<%= listing.maxGuests || 4 %>" class="form-control" min="1" step="1" required>
                <div class="invalid-feedback"> Please enter the guest capacity. </div>
            </div>
        </div>
        <div class="row">
            <div class="mb-3 col-md-8">
                <label for="location" class="form-label">Location:</label>
                <input type="text" id="location" name="location" value="<%= listing.location %>" class="form-control" placeholder="Enter location" required>
                <div class="invalid-feedback"> Please enter a valid location. </div>
            </div>
            <div class="mb-3 col-md-4">
                <label for="country" class="form-label">Country:</label>
                <input type="text" id="country" name="country" value="<%= listing.country %>" class="form-control" placeholder="Enter country" required>
                <div class="invalid-feedback"> Please enter a valid country. </div>
            </div>
        </div>
        <div class="mb-3">
            <button type="submit" class="btn btn-danger"> Update Listing </button>
        </div>
    </form>
</div>