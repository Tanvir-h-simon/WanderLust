<% layout("/layouts/boilerplate") %>

<%
    const currencyCode = (currencyPreference && currencyPreference.currency) ? currencyPreference.currency : "USD";
    const currencySymbol = (currencyPreference && currencyPreference.symbol) ? currencyPreference.symbol : "$";
    const currencyRate = (currencyPreference && currencyPreference.rate) ? currencyPreference.rate : 1;
    const currencyLocale = (currencyPreference && currencyPreference.locale) ? currencyPreference.locale : "en-US";
%>

<div class="listings-page">

<% if (guests || checkin) { %>
    <% const fmtDate = d => new Date(d + 'T00:00:00').toLocaleDateString('en-US', { month: 'short', day: 'numeric' }); %>
    <div class="search-summary">
        <i class="fa-solid fa-magnifying-glass"></i>
        <span class="search-summary-text">
            <% if (guests) { %><strong><%= guests %></strong> guest<%= Number(guests) !== 1 ? 's' : '' %><% } %>
            <% if (guests && checkin) { %> &middot; <% } %>
            <% if (checkin) { %><%= fmtDate(checkin) %><% if (checkout) { %> &ndash; <%= fmtDate(checkout) %><% } %><% } %>
        </span>
        <a href="/listings" class="search-summary-clear">Clear</a>
    </div>
<% } %>

<% if (searchQuery) { %>

    <%/* Search results view: wrapping grid */%>
    <div class="country-filter-header">
        <a href="/listings" class="back-to-all">
            <i class="fa-solid fa-arrow-left"></i> All listings
        </a>
        <h2 class="country-filter-title">
            <i class="fa-solid fa-magnifying-glass" style="font-size:1.4rem; color:#fe424d;"></i>
            Results for "<%= searchQuery %>"
        </h2>
        <p class="country-filter-count"><%= allListings.length %> listing<%= allListings.length !== 1 ? "s" : "" %> found</p>
    </div>

    <% if (allListings.length === 0) { %>
        <div class="no-results">
            <i class="fa-solid fa-magnifying-glass"></i>
            <p>No listings found for <strong>"<%= searchQuery %>"</strong>.</p>
            <a href="/listings" class="auth-link">View all listings</a>
        </div>
    <% } else { %>
        <div class="listings-grid">
            <% for (let listing of allListings) { %>
            <div class="listing-card listing-card-grid">
                <div class="card-img-wrapper">
                    <% const imageUrl = (listing.image && (listing.image.url || listing.image)) || "https://shorturl.at/Jp14Z"; %>
                    <a href="/listings/<%= listing._id %>">
                        <img src="<%= imageUrl %>" alt="<%= listing.title %>" class="card-img" loading="lazy" />
                    </a>
                    <button class="wishlist-btn <%= wishlistIds.includes(listing._id.toString()) ? 'active' : '' %>"
                            data-listing-id="<%= listing._id %>"
                            aria-label="<%= wishlistIds.includes(listing._id.toString()) ? 'Remove from wishlist' : 'Save to wishlist' %>">
                        <i class="fa-<%= wishlistIds.includes(listing._id.toString()) ? 'solid' : 'regular' %> fa-heart"></i>
                    </button>
                    <% if (currentUser && listing.owner && listing.owner.equals(currentUser._id)) { %>
                    <div class="card-actions">
                        <a href="/listings/<%= listing._id %>/edit" class="card-action-edit" title="Edit">
                            <i class="fa-solid fa-pen-to-square"></i>
                        </a>
                        <form class="card-action-form" method="POST" action="/listings/<%= listing._id %>?_method=DELETE" style="display:inline;">
                            <button type="submit" class="card-action-delete" title="Delete" onclick="return confirm('Are you sure you want to delete this listing?');">
                                <i class="fa-solid fa-trash"></i>
                            </button>
                        </form>
                    </div>
                    <% } %>
                </div>
                <div class="card-body-custom">
                    <div class="d-flex justify-content-between align-items-start gap-1">
                        <div class="card-location"><%= listing.title %></div>
                        <div class="card-rating">
                            <% if (listing.reviewCount > 0) { %>
                                <i class="fa-solid fa-star"></i> <%= listing.avgRating.toFixed(1) %>
                            <% } else { %>
                                <span class="card-rating-new">New</span>
                            <% } %>
                        </div>
                    </div>
                    <div class="card-sub"><%= listing.location %>, <%= listing.country %></div>
                    <div class="card-price">
                        <span class="price-before-tax"><span class="taka-sign"><%= currencySymbol %></span><%= Math.round((listing.price || 0) * currencyRate).toLocaleString(currencyLocale) %> <span class="per-night"><%= currencyCode %> / night</span></span>
                        <span class="price-with-tax"><span class="taka-sign"><%= currencySymbol %></span><%= Math.round((listing.price || 0) * currencyRate * 1.15).toLocaleString(currencyLocale) %> <span class="per-night"><%= currencyCode %> / night</span></span>
                    </div>
                </div>
            </div>
            <% } %>
        </div>
    <% } %>

<% } else if (countryFilter) { %>

    <%/* Country-filtered view: wrapping grid */%>
    <div class="country-filter-header">
        <a href="/listings" class="back-to-all">
            <i class="fa-solid fa-arrow-left"></i> All listings
        </a>
        <h2 class="country-filter-title">Places in <%= countryFilter %></h2>
        <p class="country-filter-count"><%= allListings.length %> listing<%= allListings.length !== 1 ? "s" : "" %> found</p>
    </div>

    <% if (allListings.length === 0) { %>
        <div class="no-results">
            <i class="fa-solid fa-magnifying-glass"></i>
            <p>No listings found in <strong><%= countryFilter %></strong>.</p>
            <a href="/listings" class="auth-link">View all listings</a>
        </div>
    <% } else { %>
        <div class="listings-grid">
            <% for (let listing of allListings) { %>
            <div class="listing-card listing-card-grid">
                <div class="card-img-wrapper">
                    <% const imageUrl = (listing.image && (listing.image.url || listing.image)) || "https://shorturl.at/Jp14Z"; %>
                    <a href="/listings/<%= listing._id %>">
                        <img src="<%= imageUrl %>" alt="<%= listing.title %>" class="card-img" loading="lazy" />
                    </a>
                    <button class="wishlist-btn <%= wishlistIds.includes(listing._id.toString()) ? 'active' : '' %>"
                            data-listing-id="<%= listing._id %>"
                            aria-label="<%= wishlistIds.includes(listing._id.toString()) ? 'Remove from wishlist' : 'Save to wishlist' %>">
                        <i class="fa-<%= wishlistIds.includes(listing._id.toString()) ? 'solid' : 'regular' %> fa-heart"></i>
                    </button>
                    <% if (currentUser && listing.owner && listing.owner.equals(currentUser._id)) { %>
                    <div class="card-actions">
                        <a href="/listings/<%= listing._id %>/edit" class="card-action-edit" title="Edit">
                            <i class="fa-solid fa-pen-to-square"></i>
                        </a>
                        <form class="card-action-form" method="POST" action="/listings/<%= listing._id %>?_method=DELETE" style="display:inline;">
                            <button type="submit" class="card-action-delete" title="Delete" onclick="return confirm('Are you sure you want to delete this listing?');">
                                <i class="fa-solid fa-trash"></i>
                            </button>
                        </form>
                    </div>
                    <% } %>
                </div>
                <div class="card-body-custom">
                    <div class="d-flex justify-content-between align-items-start gap-1">
                        <div class="card-location"><%= listing.title %></div>
                        <div class="card-rating">
                            <% if (listing.reviewCount > 0) { %>
                                <i class="fa-solid fa-star"></i> <%= listing.avgRating.toFixed(1) %>
                            <% } else { %>
                                <span class="card-rating-new">New</span>
                            <% } %>
                        </div>
                    </div>
                    <div class="card-sub"><%= listing.location %>, <%= listing.country %></div>
                    <div class="card-price">
                        <span class="price-before-tax"><span class="taka-sign"><%= currencySymbol %></span><%= Math.round((listing.price || 0) * currencyRate).toLocaleString(currencyLocale) %> <span class="per-night"><%= currencyCode %> / night</span></span>
                        <span class="price-with-tax"><span class="taka-sign"><%= currencySymbol %></span><%= Math.round((listing.price || 0) * currencyRate * 1.15).toLocaleString(currencyLocale) %> <span class="per-night"><%= currencyCode %> / night</span></span>
                    </div>
                </div>
            </div>
            <% } %>
        </div>
    <% } %>

<% } else { %>

    <%/* Default view: grouped horizontal scroll rows */%>
    <%
    const grouped = {};
    for (let lst of allListings) {
        const key = lst.country || "Other";
        if (!grouped[key]) grouped[key] = [];
        grouped[key].push(lst);
    }
    const countries = Object.keys(grouped);
    %>

    <% if (allListings.length === 0) { %>
        <div class="no-results">
            <i class="fa-solid fa-magnifying-glass"></i>
            <p>No listings found.</p>
        </div>
    <% } %>

    <% for (let i = 0; i < countries.length; i++) { %>
        <%
            const country = countries[i];
            const listings = grouped[country];
            const rowId = "row-" + i;
        %>
        <div class="listing-section mb-5">
            <div class="section-header d-flex align-items-center justify-content-between mb-3">
                <h5 class="section-title mb-0">
                    Places in <%= country %>
                    <a href="/listings?country=<%= encodeURIComponent(country) %>" class="section-arrow ms-2" title="See all in <%= country %>">
                        <i class="fa-solid fa-arrow-right-long"></i>
                    </a>
                </h5>
                <div class="scroll-controls">
                    <button class="scroll-btn scroll-prev" data-row="<%= rowId %>" aria-label="Previous" disabled>
                        <i class="fa-solid fa-chevron-left"></i>
                    </button>
                    <button class="scroll-btn scroll-next" data-row="<%= rowId %>" aria-label="Next">
                        <i class="fa-solid fa-chevron-right"></i>
                    </button>
                </div>
            </div>
            <div class="cards-row" id="<%= rowId %>">
                <% for (let listing of listings) { %>
                <div class="listing-card">
                    <div class="card-img-wrapper">
                        <% const imageUrl = (listing.image && (listing.image.url || listing.image)) || "https://shorturl.at/Jp14Z"; %>
                        <a href="/listings/<%= listing._id %>">
                            <img src="<%= imageUrl %>" alt="<%= listing.title %>" class="card-img" loading="lazy" />
                        </a>
                        <button class="wishlist-btn <%= wishlistIds.includes(listing._id.toString()) ? 'active' : '' %>"
                                data-listing-id="<%= listing._id %>"
                                aria-label="<%= wishlistIds.includes(listing._id.toString()) ? 'Remove from wishlist' : 'Save to wishlist' %>">
                            <i class="fa-<%= wishlistIds.includes(listing._id.toString()) ? 'solid' : 'regular' %> fa-heart"></i>
                        </button>
                        <% if (currentUser && listing.owner && listing.owner.equals(currentUser._id)) { %>
                        <div class="card-actions">
                            <a href="/listings/<%= listing._id %>/edit" class="card-action-edit" title="Edit">
                                <i class="fa-solid fa-pen-to-square"></i>
                            </a>
                            <form class="card-action-form" method="POST" action="/listings/<%= listing._id %>?_method=DELETE" style="display:inline;">
                                <button type="submit" class="card-action-delete" title="Delete" onclick="return confirm('Are you sure you want to delete this listing?');">
                                    <i class="fa-solid fa-trash"></i>
                                </button>
                            </form>
                        </div>
                        <% } %>
                    </div>
                    <div class="card-body-custom">
                        <div class="d-flex justify-content-between align-items-start gap-1">
                            <div class="card-location"><%= listing.title %></div>
                            <div class="card-rating">
                                <% if (listing.reviewCount > 0) { %>
                                    <i class="fa-solid fa-star"></i> <%= listing.avgRating.toFixed(1) %>
                                <% } else { %>
                                    <span class="card-rating-new">New</span>
                                <% } %>
                            </div>
                        </div>
                        <div class="card-sub"><%= listing.location %>, <%= listing.country %></div>
                        <div class="card-price">
                            <span class="price-before-tax"><span class="taka-sign"><%= currencySymbol %></span><%= Math.round((listing.price || 0) * currencyRate).toLocaleString(currencyLocale) %> <span class="per-night"><%= currencyCode %> / night</span></span>
                            <span class="price-with-tax"><span class="taka-sign"><%= currencySymbol %></span><%= Math.round((listing.price || 0) * currencyRate * 1.15).toLocaleString(currencyLocale) %> <span class="per-night"><%= currencyCode %> / night</span></span>
                        </div>
                    </div>
                </div>
                <% } %>
            </div>
        </div>
    <% } %>

<% } %>

</div>

<script>
    const isLoggedIn = <%- !!currentUser %>;

    document.querySelectorAll('.wishlist-btn').forEach(btn => {
        btn.addEventListener('click', async function (e) {
            e.preventDefault();
            if (!isLoggedIn) {
                window.location.href = '/login';
                return;
            }
            const listingId = this.dataset.listingId;
            const icon = this.querySelector('i');
            try {
                const resp = await fetch(`/listings/${listingId}/wishlist`, { method: 'POST' });
                if (resp.ok) {
                    const { wishlisted } = await resp.json();
                    icon.classList.toggle('fa-regular', !wishlisted);
                    icon.classList.toggle('fa-solid', wishlisted);
                    this.classList.toggle('active', wishlisted);
                    this.setAttribute('aria-label', wishlisted ? 'Remove from wishlist' : 'Save to wishlist');
                }
            } catch (_) {}
        });
    });

    document.querySelectorAll('.scroll-prev, .scroll-next').forEach(btn => {
        btn.addEventListener('click', function () {
            const rowId = this.dataset.row;
            const direction = this.classList.contains('scroll-next') ? 1 : -1;
            const row = document.getElementById(rowId);
            const card = row.querySelector('.listing-card');
            if (!card) return;
            const cardWidth = card.offsetWidth + 16;
            const visibleCount = Math.max(1, Math.floor(row.offsetWidth / cardWidth));
            row.scrollBy({ left: direction * cardWidth * visibleCount, behavior: 'smooth' });
        });
    });

    document.querySelectorAll('.cards-row').forEach(row => {
        function updateButtons() {
            const rowId = row.id;
            const prev = document.querySelector(`.scroll-prev[data-row="${rowId}"]`);
            const next = document.querySelector(`.scroll-next[data-row="${rowId}"]`);
            const atStart = row.scrollLeft <= 2;
            const atEnd = row.scrollLeft + row.offsetWidth >= row.scrollWidth - 2;
            if (prev) prev.disabled = atStart;
            if (next) next.disabled = atEnd;
        }
        row.addEventListener('scroll', updateButtons, { passive: true });
        updateButtons();
    });
</script>
