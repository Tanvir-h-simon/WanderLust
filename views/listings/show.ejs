<% layout("/layouts/boilerplate") %>
<%
  const isOwner = currentUser && listing.owner &&
                  listing.owner._id.equals(currentUser._id);

  const avgRating = listing.reviews && listing.reviews.length > 0
    ? (listing.reviews.reduce((sum, r) => sum + r.rating, 0) / listing.reviews.length).toFixed(1)
    : null;

    const currencyCode = (currencyPreference && currencyPreference.currency) ? currencyPreference.currency : "USD";
    const currencySymbol = (currencyPreference && currencyPreference.symbol) ? currencyPreference.symbol : "$";
    const currencyRate = (currencyPreference && currencyPreference.rate) ? currencyPreference.rate : 1;
    const locale = (currencyPreference && currencyPreference.locale) ? currencyPreference.locale : "en-US";
    const convertedPrice = Math.round((listing.price || 0) * currencyRate);
%>

<div class="container listing-details-container">
    <h1 class="listing-details-heading"><%= listing.title %></h1>

    <% const imageUrl = (listing.image && (listing.image.url || listing.image)) || "https://shorturl.at/Jp14Z"; %>
    <div class="listing-image-wrapper">
        <img src="<%= imageUrl %>" alt="<%= listing.title %>" class="listing-image" />
    </div>

    <ul class="listing-info">
        <% if (listing.owner) { %>
        <li>
            <strong>Owner:</strong>
            <span class="listing-owner-badge">
                <i class="fa-solid fa-circle-user"></i> <%= listing.owner.username %>
            </span>
        </li>
        <% } %>
        <li><strong>Description:</strong> <%= listing.description %></li>
        <li><strong>Price:</strong>
            <span class="price-before-tax"><span class="taka-sign"><%= currencySymbol %></span> <%= convertedPrice.toLocaleString(locale) %> <%= currencyCode %> / night</span>
            <span class="price-with-tax"><span class="taka-sign"><%= currencySymbol %></span> <%= Math.round(convertedPrice * 1.15).toLocaleString(locale) %> <%= currencyCode %> / night</span>
        </li>
        <li><strong>Guests:</strong> up to <%= listing.maxGuests || 4 %></li>
        <li><strong>Location:</strong> <%= listing.location %></li>
        <li><strong>Country:</strong> <%= listing.country %></li>
    </ul>

    <%# Map %>
    <% if (listing.geometry && listing.geometry.coordinates && listing.geometry.coordinates.length === 2) { %>
    <div class="listing-map-section">
        <h3 class="listing-map-heading">Where you'll be</h3>
        <div id="listing-map"></div>
    </div>
    <% } %>

    <% if (isOwner) { %>
    <div class="listing-actions">
        <a href="/listings/<%= listing._id %>/edit" class="action-btn btn-edit">
            <i class="fa-solid fa-pen-to-square"></i> Edit this listing
        </a>
        <form class="action-form" method="POST" action="/listings/<%= listing._id %>?_method=DELETE">
            <button type="submit" class="action-btn btn-delete">
                <i class="fa-solid fa-trash"></i> Delete this listing
            </button>
        </form>
    </div>
    <% } %>

    <%/* Reviews Section */%>
    <div class="reviews-section">
        <div class="reviews-header">
            <h2 class="reviews-title">Guest Reviews</h2>
            <% if (avgRating) { %>
            <div class="reviews-summary">
                <span class="avg-rating-badge">
                    <i class="fa-solid fa-star"></i> <%= avgRating %>
                </span>
                <span class="review-count">(<%= listing.reviews.length %> review<%= listing.reviews.length !== 1 ? "s" : "" %>)</span>
            </div>
            <% } %>
        </div>

        <%/* Review form: only for logged-in users */%>
        <div class="reviews-form-section">
            <% if (currentUser) { %>
                <h3 class="form-heading">Share your experience</h3>
                <form class="review-form needs-validation" action="/listings/<%= listing._id %>/reviews" method="POST" novalidate>
                    <div class="form-group">
                        <label class="form-label">Rating <span class="text-danger">*</span></label>
                        <div class="star-rating">
                            <input type="radio" name="rating" value="5" id="star5" class="star-input" required>
                            <label for="star5" class="star-label"><i class="fa-solid fa-star"></i></label>
                            <input type="radio" name="rating" value="4" id="star4" class="star-input">
                            <label for="star4" class="star-label"><i class="fa-solid fa-star"></i></label>
                            <input type="radio" name="rating" value="3" id="star3" class="star-input">
                            <label for="star3" class="star-label"><i class="fa-solid fa-star"></i></label>
                            <input type="radio" name="rating" value="2" id="star2" class="star-input">
                            <label for="star2" class="star-label"><i class="fa-solid fa-star"></i></label>
                            <input type="radio" name="rating" value="1" id="star1" class="star-input">
                            <label for="star1" class="star-label"><i class="fa-solid fa-star"></i></label>
                            <div class="invalid-feedback">Please select a rating.</div>
                        </div>
                    </div>
                    <div class="form-group">
                        <label for="review-text" class="form-label">Your Review <span class="text-danger">*</span></label>
                        <textarea id="review-text" name="comment" class="review-textarea form-control"
                            placeholder="Share your thoughts... (10–500 characters)"
                            minlength="10" maxlength="500" required></textarea>
                        <div class="invalid-feedback">Review must be at least 10 characters.</div>
                    </div>
                    <button type="submit" class="submit-review-btn">Submit Review</button>
                </form>
            <% } else { %>
                <div class="review-login-prompt">
                    <i class="fa-solid fa-lock"></i>
                    <p><a href="/login" class="auth-link">Log in</a> to leave a review.</p>
                </div>
            <% } %>
        </div>

        <%/* Reviews list */%>
        <div class="reviews-list">
            <% if (listing.reviews && listing.reviews.length > 0) { %>
                <% listing.reviews.forEach(review => { %>
                <%
                    const isReviewAuthor = currentUser && review.user &&
                                          review.user._id.equals(currentUser._id);
                %>
                <div class="review-card">
                    <div class="review-header">
                        <div class="reviewer-info">
                            <div class="reviewer-avatar">
                                <%= review.user ? review.user.username.substring(0, 2).toUpperCase() : "??" %>
                            </div>
                            <div>
                                <div class="reviewer-name">
                                    <%= review.user ? review.user.username : "Anonymous" %>
                                </div>
                                <div class="review-date">
                                    <%= new Date(review.createdAt).toLocaleDateString('en-US', { year: 'numeric', month: 'long' }) %>
                                </div>
                            </div>
                        </div>
                        <div class="review-header-right">
                            <div class="review-rating">
                                <% for (let i = 0; i < 5; i++) { %>
                                    <i class="fa-<%= i < review.rating ? 'solid' : 'regular' %> fa-star"></i>
                                <% } %>
                            </div>
                            <% if (isReviewAuthor) { %>
                                <form method="POST" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE" style="display:inline;">
                                    <button type="submit" class="review-delete-btn" title="Delete your review"
                                        onclick="return confirm('Delete your review?');">
                                        <i class="fa-solid fa-trash"></i>
                                    </button>
                                </form>
                            <% } %>
                        </div>
                    </div>
                    <p class="review-text"><%= review.comment %></p>
                </div>
                <% }); %>
            <% } else { %>
                <p class="no-reviews-msg">No reviews yet. Be the first to share your experience!</p>
            <% } %>
        </div>
    </div>
</div>

<% if (listing.geometry && listing.geometry.coordinates && listing.geometry.coordinates.length === 2) { %>
<script src="https://api.mapbox.com/mapbox-gl-js/v3.4.0/mapbox-gl.js"></script>
<script>
    mapboxgl.accessToken = '<%- mapboxToken %>';
    const coords = <%- JSON.stringify(listing.geometry.coordinates) %>;

    const map = new mapboxgl.Map({
        container: 'listing-map',
        style: 'mapbox://styles/mapbox/streets-v12',
        center: coords,
        zoom: 10,
        scrollZoom: false
    });

    map.addControl(new mapboxgl.NavigationControl(), 'top-right');
    map.addControl(new mapboxgl.FullscreenControl(), 'top-right');

    const _t = <%- JSON.stringify(listing.title    || '').replace(/</g,'\\u003c').replace(/>/g,'\\u003e') %>;
    const _l = <%- JSON.stringify((listing.location || '') + ', ' + (listing.country || '')).replace(/</g,'\\u003c').replace(/>/g,'\\u003e') %>;
    function _esc(s) { return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }

    const popup = new mapboxgl.Popup({
        offset: 25,
        closeButton: true,
        closeOnClick: false,
        maxWidth: '260px'
    }).setHTML(
        '<div class="map-popup">' +
            '<div class="map-popup-title">' + _esc(_t) + '</div>' +
            '<div class="map-popup-location"><i class="fa-solid fa-location-dot"></i> ' + _esc(_l) + '</div>' +
            '<div class="map-popup-price"><span class="map-popup-taka"><%= currencySymbol %></span><%= convertedPrice.toLocaleString(locale) %> <span class="map-popup-night"> <%= currencyCode %> / night</span></div>' +
        '</div>'
    );

    const marker = new mapboxgl.Marker({ color: '#fe424d' })
        .setLngLat(coords)
        .setPopup(popup)
        .addTo(map);

    map.on('load', () => marker.togglePopup());
</script>
<% } %>
