      </div>
    </div>
  </div>

  <div class="footer-bottom">
    <div class="container">
      <% const footerLanguage = 'English (US)'; %>
      <% const footerCurrency = (currencyPreference && currencyPreference.currency) ? currencyPreference.currency : 'USD'; %>
      <% const footerSymbol = (currencyPreference && currencyPreference.symbol) ? currencyPreference.symbol : '$'; %>

      <div class="d-flex flex-wrap justify-content-between align-items-center gap-2">
        <span>
          &copy; 2026 WanderLust, Inc. &middot;
          <a href="#">Privacy</a> &middot; <a href="#">Terms</a> &middot;
          <a href="#">Sitemap</a>
        </span>
        <span>
          <i class="fa-solid fa-globe me-1"></i>
          <span id="wlFooterLanguage"
                style="cursor:pointer; text-decoration:underline;"
                data-bs-toggle="modal"
                data-bs-target="#currencyModal">
            <%= footerLanguage %>
          </span>
          &nbsp;&nbsp;
          <span id="wlFooterCurrency"><%= footerSymbol %> <%= footerCurrency %></span>
        </span>
      </div>
    </div>
  </div>
</footer>

<!-- Currency Picker Modal -->
<div class="modal fade" id="currencyModal" tabindex="-1" aria-labelledby="currencyModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="currencyModalLabel">Choose your currency</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <form action="/preferences/currency" method="POST">
          <div class="d-flex flex-column gap-3">
            <div class="form-check">
              <input class="form-check-input" type="radio" name="currency"
                     id="currencyUsd" value="USD"
                     <%= footerCurrency === 'USD' ? 'checked' : '' %>>
              <label class="form-check-label" for="currencyUsd">
                <span class="text-muted">$</span> USD (US Dollar)
              </label>
            </div>
            <div class="form-check">
              <input class="form-check-input" type="radio" name="currency"
                     id="currencyBdt" value="BDT"
                     <%= footerCurrency === 'BDT' ? 'checked' : '' %>>
              <label class="form-check-label" for="currencyBdt">
                <span class="text-muted">৳</span> BDT (Bangladeshi Taka)
              </label>
            </div>
          </div>
          <div class="mt-4">
            <button type="submit" class="btn btn-dark w-100">Save</button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>