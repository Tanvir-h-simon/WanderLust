        </div>
        <div class="col-lg-3 col-md-6 mb-4">
          <h6 class="footer-heading">Hosting</h6>
          <ul class="footer-links">
            <li><a href="/listings/new">List your property</a></li>
            <li><a href="#">AirCover for Hosts</a></li>
            <li><a href="#">Hosting resources</a></li>
            <li><a href="#">Community forum</a></li>
            <li><a href="#">Hosting responsibly</a></li>
          </ul>
        </div>
        <div class="col-lg-3 col-md-6 mb-4">
          <h6 class="footer-heading">WanderLust</h6>
          <ul class="footer-links">
            <li><a href="#">Newsroom</a></li>
            <li><a href="#">New features</a></li>
            <li><a href="#">Careers</a></li>
            <li><a href="#">Investors</a></li>
            <li><a href="#">Gift cards</a></li>
          </ul>
        </div>
        <div class="col-lg-3 col-md-6 mb-4">
          <h6 class="footer-heading">Follow us</h6>
          <ul class="footer-links">
            <li><a href="#"><i class="fa-brands fa-facebook me-2"></i>Facebook</a></li>
            <li><a href="#"><i class="fa-brands fa-twitter me-2"></i>Twitter</a></li>
            <li><a href="#"><i class="fa-brands fa-instagram me-2"></i>Instagram</a></li>
