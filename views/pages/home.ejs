<% layout("/layouts/boilerplate") %>

<!-- Hero Section with Search Bar -->
<div class="hero-section">
    <div class="hero-content">
        <form class="search-bar" action="/listings" method="GET">
            <div class="search-group where-group">
                <label for="where">Where</label>
                <input type="text" id="where" name="location" placeholder="Search destinations" class="search-input">
            </div>
            
            <div class="search-group when-group">
                <label for="when">When</label>
                <input type="date" id="when" name="date" class="search-input">
            </div>
            
            <div class="search-group who-group">
                <label for="who">Who</label>
                <input type="text" id="who" name="guests" placeholder="Add guests" class="search-input">
            </div>
            
            <button type="submit" class="search-btn">
                <i class="fa-solid fa-magnifying-glass"></i>
            </button>
        </form>
    </div>
</div>

<!-- Featured Listings -->
<div class="container featured-container">
    <h2 class="featured-heading">Featured Listings</h2>
    <p class="featured-subtext">Check out some of our best destinations</p>
    
    <div class="featured-listings">
        <% if (featuredListings && featuredListings.length > 0) { %>
            <% featuredListings.forEach((item) => { %>
                <div class="featured-card">
                    <div class="featured-img-wrapper">
                        <% const imageUrl = (item.image && (item.image.url || item.image)) || "https://shorturl.at/Jp14Z"; %>
                        <img src="<%= imageUrl %>" alt="<%= item.title %>" class="featured-img" />
                        <div class="featured-overlay">
                            <a href="/listings/<%= item._id %>" class="featured-view-btn">View Details</a>
                        </div>
                    </div>
                    <div class="featured-info">
                        <h3 class="featured-title"><%= item.title %></h3>
                        <p class="featured-location">
                            <i class="fa-solid fa-location-dot"></i> <%= item.location %>, <%= item.country %>
                        </p>
                        <p class="featured-price">
                            <span class="taka-sign">৳</span><%= item.price.toLocaleString("en-BD") %> <span class="per-night">/ night</span>
                        </p>
                    </div>
                </div>
            <% }); %>
        <% } else { %>
            <p class="no-listings">No featured listings available</p>
        <% } %>
    </div>
    
    <div class="view-all-container">
        <a href="/listings" class="view-all-btn">View All Listings</a>
    </div>
</div>
